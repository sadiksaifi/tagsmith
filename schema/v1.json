{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://tagsmith.sadiksaifi.dev/schema/v1.json",
  "$comment": "Runtime-only v1 constraints: target path existence, realpath containment, and realpath uniqueness; channel dependency references, self-dependencies, cycles, and channel-name uniqueness; effective inherited values; multi-target tag-pattern ambiguity; remaining rendered Git tag validation; and tagMessage non-empty after interpolation are enforced by Tagsmith runtime validation.",
  "title": "Tagsmith config v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["configVersion", "git", "defaults", "targets"],
  "properties": {
    "$schema": { "type": "string" },
    "configVersion": { "const": 1 },
    "git": {
      "type": "object",
      "additionalProperties": false,
      "required": ["remote", "baseBranch"],
      "properties": {
        "remote": {
          "type": "string",
          "minLength": 1,
          "pattern": "^(?!-)(?!\\.)(?!.*\\.lock$)(?!.*\\.\\.)(?!.*@\\{)(?!@$)(?!.*[\\x00-\\x20\\x7f/~^:?*\\[\\\\]).+$"
        },
        "baseBranch": {
          "type": "string",
          "minLength": 1,
          "pattern": "^(?!HEAD$)(?!origin/)(?!refs/)(?!-)(?!/)(?!.*//)(?!.*(?:^|/)\\.)(?!.*\\.lock(?:/|$))(?!.*\\.\\.)(?!.*@\\{)(?!@$)(?!.*[\\x00-\\x20\\x7f~^:?*\\[\\\\])(?!.*\\.$).+$"
        }
      }
    },
    "defaults": { "$ref": "#/$defs/defaults" },
    "targets": {
      "type": "object",
      "minProperties": 1,
      "propertyNames": { "$ref": "#/$defs/name" },
      "additionalProperties": { "$ref": "#/$defs/target" }
    }
  },
  "$defs": {
    "name": { "type": "string", "pattern": "^[a-z][a-z0-9-]*$" },
    "stableSemver": {
      "type": "string",
      "pattern": "^(?:0|[1-9][0-9]{0,14}|[1-8][0-9]{15}|900[0-6][0-9]{12}|90070[0-9]{11}|90071[0-8][0-9]{10}|900719[0-8][0-9]{9}|9007199[0-1][0-9]{8}|90071992[0-4][0-9]{7}|900719925[0-3][0-9]{6}|9007199254[0-6][0-9]{5}|90071992547[0-3][0-9]{4}|9007199254740[0-8][0-9]{2}|90071992547409[0-8][0-9]|9007199254740990|9007199254740991)\\.(?:0|[1-9][0-9]{0,14}|[1-8][0-9]{15}|900[0-6][0-9]{12}|90070[0-9]{11}|90071[0-8][0-9]{10}|900719[0-8][0-9]{9}|9007199[0-1][0-9]{8}|90071992[0-4][0-9]{7}|900719925[0-3][0-9]{6}|9007199254[0-6][0-9]{5}|90071992547[0-3][0-9]{4}|9007199254740[0-8][0-9]{2}|90071992547409[0-8][0-9]|9007199254740990|9007199254740991)\\.(?:0|[1-9][0-9]{0,14}|[1-8][0-9]{15}|900[0-6][0-9]{12}|90070[0-9]{11}|90071[0-8][0-9]{10}|900719[0-8][0-9]{9}|9007199[0-1][0-9]{8}|90071992[0-4][0-9]{7}|900719925[0-3][0-9]{6}|9007199254[0-6][0-9]{5}|90071992547[0-3][0-9]{4}|9007199254740[0-8][0-9]{2}|90071992547409[0-8][0-9]|9007199254740990|9007199254740991)$"
    },
    "tagPattern": {
      "type": "string",
      "allOf": [
        { "pattern": "^(?:[a-z0-9._@-]|\\{target\\}|\\{version\\})+$" },
        { "pattern": "\\{version\\}" },
        { "not": { "pattern": "\\{version\\}.*\\{version\\}" } },
        { "not": { "pattern": "\\{target\\}.*\\{target\\}" } },
        { "not": { "pattern": "^[.-]" } },
        { "not": { "pattern": "\\.$" } },
        { "not": { "pattern": "\\.\\." } },
        { "not": { "pattern": "\\.lock$" } }
      ]
    },
    "tagMessage": {
      "type": "string",
      "allOf": [
        { "pattern": "^[^\\u0000-\\u001f\\u007f-\\u009f\\u2028\\u2029]*$" },
        { "not": { "pattern": "\\{(?!(?:target|version|tag)\\})[^}]*\\}" } }
      ]
    },
    "defaults": {
      "type": "object",
      "additionalProperties": false,
      "required": ["tagPattern", "tagMessage", "initialVersion"],
      "properties": {
        "tagPattern": { "$ref": "#/$defs/tagPattern" },
        "tagMessage": { "$ref": "#/$defs/tagMessage" },
        "initialVersion": { "$ref": "#/$defs/stableSemver" }
      }
    },
    "target": {
      "type": "object",
      "additionalProperties": false,
      "required": ["path", "channels"],
      "properties": {
        "path": { "type": "string" },
        "channels": { "$ref": "#/$defs/channels" },
        "tagPattern": { "$ref": "#/$defs/tagPattern" },
        "tagMessage": { "$ref": "#/$defs/tagMessage" },
        "initialVersion": { "$ref": "#/$defs/stableSemver" }
      }
    },
    "channels": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/channel" },
      "contains": {
        "type": "object",
        "required": ["strategy"],
        "properties": { "strategy": { "const": "stable" } }
      },
      "minContains": 1,
      "maxContains": 1
    },
    "channel": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "strategy"],
      "properties": {
        "name": { "$ref": "#/$defs/name" },
        "strategy": { "enum": ["prerelease", "stable"] },
        "dependsOn": {
          "type": "array",
          "items": { "$ref": "#/$defs/name" }
        }
      }
    }
  }
}
