{
  "name": "tagsmith",
  "version": "0.0.0",
  "description": "Opinionated Git tag and SemVer release-tag manager.",
  "keywords": [
    "cli",
    "git",
    "release",
    "semver",
    "tags"
  ],
  "homepage": "https://github.com/sadiksaifi/tagsmith#readme",
  "bugs": {
    "url": "https://github.com/sadiksaifi/tagsmith/issues"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/sadiksaifi/tagsmith.git"
  },
  "bin": {
    "tagsmith": "./dist/cli.js"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "scripts": {
    "dev": "tsdown --watch",
    "build": "tsdown",
    "prepack": "pnpm build",
    "prepare": "husky",
    "check": "pnpm typecheck && pnpm lint && pnpm format:check && pnpm test",
    "check:commit": "pnpm typecheck && pnpm lint && pnpm format:check && pnpm test:unit",
    "check:push": "pnpm test:integration && pnpm test:e2e",
    "typecheck": "tsc --noEmit",
    "lint": "oxlint . --deny-warnings",
    "lint:fix": "oxlint . --fix",
    "format": "oxfmt . --write",
    "format:check": "oxfmt . --check",
    "test": "pnpm test:unit && pnpm test:integration && pnpm test:e2e",
    "test:unit": "vitest run src test/unit",
    "test:integration": "vitest run test/integration",
    "test:e2e": "pnpm build && vitest run test/e2e",
    "coverage": "vitest run src test/unit test/integration --coverage",
    "test:watch": "vitest"
  },
  "dependencies": {
    "cac": "^7.0.0",
    "jsonc-parser": "^3.3.1",
    "picocolors": "^1.1.1",
    "semver": "^7.7.4",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^22.19.17",
    "@types/semver": "^7.7.1",
    "@vitest/coverage-v8": "^4.1.5",
    "husky": "^9.1.7",
    "oxfmt": "^0.47.0",
    "oxlint": "^1.62.0",
    "oxlint-tsgolint": "^0.22.1",
    "tsdown": "^0.21.10",
    "typescript": "^6.0.3",
    "vitest": "^4.1.5"
  },
  "engines": {
    "node": ">=22"
  },
  "packageManager": "pnpm@10.33.0"
}
